# ============================================================
# LogiRisk AI — .gitignore
# ============================================================

# ─── Private / Internal Docs (not for judges) ────────────────
LogiRisk_Architecture_Overview.txt

# ============================================================
# LogiRisk AI — .gitignore
# ============================================================

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual Environments ────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Environment Variables (NEVER commit secrets) ────────────
.env
.env.local
.env.*.local

# ─── Database (live data, regenerated on run) ────────────────
*.db
*.sqlite
*.sqlite3

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
uvicorn.log

# ─── ML Artifacts (large binaries) ──────────────────────────
*.pkl
*.pickle
*.h5
*.pt
*.pth
*.onnx
ml/models/*.pkl
ml/models/*.h5

# ─── Frontend — Node / Vite ──────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env
frontend/.env.local

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Legacy Streamlit (no longer used) ───────────────────────
.streamlit/

# ─── Test / Scratch ──────────────────────────────────────────
test_api.py
test.py
scratch/